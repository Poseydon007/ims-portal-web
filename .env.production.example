# Production environment template for ims-portal.site deployment.
# Copy to .env on the VPS at /opt/ims-portal/.env (NEVER commit the real one).

# ─── Public URL ──────────────────────────────────────────────────────────────
PORTAL_HOST=ims-portal.site
PORTAL_URL=https://ims-portal.site

# ─── MySQL credentials (consumed by docker-compose.prod.yml) ─────────────────
# Generate strong random values: openssl rand -base64 24
MYSQL_ROOT_PASSWORD=replace-me-strong-random-string
MYSQL_DATABASE=ims_portal
MYSQL_USER=ims_app
MYSQL_PASSWORD=replace-me-strong-random-string

# ─── App secrets ─────────────────────────────────────────────────────────────
# 64-char hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-64-char-hex

# ─── Optional integrations (leave blank for first deploy) ────────────────────
# Email notifications via SendPulse SMTP relay (Gmail-compatible)
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# SENDPULSE_API_KEY=

# Google Drive for register attachments (admin-side feature)
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Manus-era runtime (NOT used in current deployment; leave blank)
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
