---
const LOGO_WHITE = "https://d2xsxph8kpxj0f.cloudfront.net/310519663473952399/3YVZojsY2rei5QwThHiV6E/trueeastlogoWHITE_79ded02e.png";
---

<header
  style="background-color: #081C2E; border-bottom: 3px solid #C49A28;"
  class="sticky top-0 z-50 shadow-lg"
>
  <div class="container flex items-stretch justify-between" style="min-height: 72px;">
    <a href="/" class="flex items-center gap-3 no-underline group py-3 flex-shrink-0">
      <img
        src={LOGO_WHITE}
        alt="True East Mining Company"
        style="width: 52px; height: 52px; object-fit: contain;"
        class="opacity-90 group-hover:opacity-100 transition-opacity"
      />
      <div class="hidden sm:block">
        <div class="text-white font-bold text-sm leading-tight tracking-wide">
          TRUE EAST MINING COMPANY
        </div>
        <div style="color: #C49A28;" class="text-xs font-light tracking-widest">
          الشرق الحقيقي
        </div>
      </div>
    </a>

    <div class="flex flex-col items-center justify-center px-4 gap-1.5 flex-1">
      <div class="flex items-center gap-1 flex-wrap justify-center">
        <a href="/" class="text-xs font-semibold px-3 py-1 rounded transition-all duration-200 hover:bg-white/10 whitespace-nowrap" style="color: rgba(255,255,255,0.85);">
          Home
        </a>
      </div>
    </div>

    <div
      class="flex flex-col items-end justify-center py-3 pl-4 flex-shrink-0"
      style="border-left: 1px solid rgba(255,255,255,0.1);"
    >
      <div class="text-right">
        <div class="text-white text-xs font-semibold tracking-widest uppercase opacity-80">
          IMS Document Portal
        </div>
        <div class="text-white text-xs opacity-40 tracking-wide">
          Internal Use Only
        </div>
      </div>
    </div>
  </div>
</header>
