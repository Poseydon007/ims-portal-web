NODE_ENV=development
PORT=3000

# Matches docker-compose.dev.yml defaults; change for prod.
DATABASE_URL=mysql://ims_app:devapp@localhost:3306/ims_portal

# Generate a fresh secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-64-char-hex

# Optional — leave blank unless the deploy uses Manus-era OAuth flow.
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=
